window.updateTimelineUI = function() {
    if(!window.globalProjectStart||!window.globalProjectEnd)return;
    const start=new Date(window.globalProjectStart+"T00:00:00").getTime(); const end=new Date(window.globalProjectEnd+"T23:59:59").getTime(); const now=new Date().getTime(); const tot=end-start; if(tot<=0)return;
    let rem=end-now; let del=rem<0; if(del)rem=Math.abs(rem);
    let dPct=parseFloat(window.globalProjectProgress)||0; if(dPct<0)dPct=0; if(dPct>100)dPct=100; let rPct=100-dPct;
    const d=Math.floor(rem/(1000*60*60*24)); const h=Math.floor((rem%(1000*60*60*24))/(1000*60*60)); const m=Math.floor((rem%(1000*60*60))/(1000*60)); const s=Math.floor((rem%(1000*60))/1000);
    document.getElementById('stat-total-days').innerText=Math.ceil(tot/(1000*60*60*24)); document.getElementById('stat-remaining-days').innerText=del?"0":d;
    document.getElementById('cd-days').innerText=String(d).padStart(2,'0'); document.getElementById('cd-hours').innerText=String(h).padStart(2,'0'); document.getElementById('cd-mins').innerText=String(m).padStart(2,'0'); document.getElementById('cd-secs').innerText=String(s).padStart(2,'0');
    let bClass='bg-emerald-50 text-emerald-700'; let bTxt='ON SCHEDULE';
    if(del){bClass='bg-rose-50 text-rose-700';bTxt='DELAYED';document.getElementById('timeline-status-label').innerText="OVERDUE BY";document.getElementById('timeline-progress-done').className="h-full bg-rose-500";}else{document.getElementById('timeline-status-label').innerText="TARGET COMPLETION";document.getElementById('timeline-progress-done').className="h-full bg-indigo-500";if(d<30){bClass='bg-rose-50 text-rose-700';bTxt='CRITICAL (<30 DAYS)';}else if(d<=90){bClass='bg-orange-50 text-orange-700';bTxt='FINAL (<90 DAYS)';}}
    document.getElementById('timeline-badge').className=`px-3 py-1.5 text-[10px] uppercase font-bold rounded-full ${bClass}`; document.getElementById('badge-text').innerText=bTxt;
    document.getElementById('timeline-progress-done').style.width=`${dPct}%`; document.getElementById('timeline-progress-rem').style.width=`${rPct}%`;
}

