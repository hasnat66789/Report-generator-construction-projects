window.previewReport = function() {
    window.generatedReport={projectName:window.formData.projectName||'Project',clientName:window.formData.clientName,location:window.formData.location,supervisionConsultant:window.formData.supervisionConsultant,referenceNo:window.formData.referenceNo||'DRAFT',date:window.formData.date,shift:window.formData.shift,markdown:window.buildMarkdownFromForm(),photos:document.getElementById('cfg-include-photos').checked?window.photos:[],coverPhoto:window.currentReportCoverBase64,logo:window.companyLogoBase64,headerLayout:document.getElementById('cfg-header-layout').value,reviewStatus:'Draft',preparedBy:window.globalProfile.name};
    window.renderFinalToContainer(window.generatedReport, document.getElementById('preview-paper'), false); document.getElementById('preview-modal').classList.remove('hidden');
}

window.resetReportForm = function() {
    const keepLookAhead = document.getElementById('lock-lookahead-toggle') && document.getElementById('lock-lookahead-toggle').checked;
    document.getElementById('draft-exec-summary').value=''; document.getElementById('draft-completed-today').value=''; document.getElementById('draft-safety-quality').value='';
    window.photos=[]; window.renderPhotos(); window.autoSaveMainPhotosLocal();
    if (!keepLookAhead) { window.lookAheadData=[{id:Date.now(),zone:'',location:'',trade:'',activity:'',target:'',remarks:''}]; window.renderLookAheadTable(); window.removeLookAheadImage(); window.autoSaveLookAheadLocal(); }
    document.getElementById('manual-review-panel').classList.add('hidden'); document.getElementById('draft-button-container').classList.remove('hidden');
}

window.generateFinalReport = async function() {
    const btn=document.getElementById('generate-report-btn'); const o=btn.innerHTML; btn.innerHTML='Saving...'; btn.disabled=true;
    try{
        const id=Math.random().toString(36).substr(2,9); const ref=window.formData.referenceNo||`DPR-${window.formData.date.replace(/-/g,'')}-${Math.floor(Math.random()*1000)}`;
        window.generatedReport={dbId:id,docId:id,projectName:window.formData.projectName||'Project',clientName:window.formData.clientName,location:window.formData.location,supervisionConsultant:window.formData.supervisionConsultant,referenceNo:ref,date:window.formData.date,shift:window.formData.shift,markdown:window.buildMarkdownFromForm(),photos:document.getElementById('cfg-include-photos').checked?[...window.photos]:[],coverPhoto:window.currentReportCoverBase64,logo:window.companyLogoBase64,headerLayout:document.getElementById('cfg-header-layout').value,reviewStatus:'Open',reviewRemarks:'',reviewActionTaken:'',preparedBy:window.globalProfile.name,views:0,viewers:[],createdAt:Date.now()};
        window.reportsList.unshift(window.generatedReport); window.updateReportsTables();
        if(db&&currentUser){
            const sp=window.generatedReport.photos.map(p=>({id:p.id,category:p.category,aiText:p.aiText,mimeType:p.mimeType}));
            const {logo,coverPhoto,...rObj}=window.generatedReport; await setDoc(doc(db,'artifacts',appFirebaseId,'public','data','reports',id),{...rObj,photos:sp});
            if(window.generatedReport.photos){for(const p of window.generatedReport.photos){if(p.base64)await setDoc(doc(db,'artifacts',appFirebaseId,'public','data','reports',id,'photos',p.id),{base64:p.base64,mimeType:p.mimeType,id:p.id});}}
        }
        window.resetReportForm();
        window.renderViewReport('final'); window.switchView('view_report'); window.showCustomAlert("Success","Report saved!");
    }catch(e){window.showCustomAlert("Error",e.message);}finally{btn.innerHTML=o;btn.disabled=false;}
}

window.renderViewReport = function(t='final') { const p=document.getElementById(t==='preview'?'preview-paper':'report-paper'); if(!p||!window.generatedReport)return; window.renderFinalToContainer(window.generatedReport,p,t==='final'); if(t==='final')window.renderReviewPanel(); }
window.renderFinalToContainer = function(r, p, inc) {
    if(!r)return; let pMd=`<pre class="font-sans text-sm whitespace-pre-wrap">${r.markdown}</pre>`;
    if(typeof marked!=='undefined'){try{pMd=marked.parse?marked.parse(r.markdown):marked(r.markdown);}catch(e){}}
    
    let h=''; const isC=r.headerLayout==='compact';
    if(r.headerLayout==='minimal'){
        h+=`<div class="border-b-2 border-slate-800 pb-4 flex justify-between items-end gap-4"><div class="flex items-center gap-4">${r.logo?`<img src="${r.logo}" class="h-10"/>`:''}<div><h1 class="text-2xl font-black uppercase m-0 leading-none">Daily Progress Report</h1><p class="text-sm font-bold text-indigo-700 mt-1">${r.projectName}</p></div></div><div class="text-right text-xs"><p><strong>Date:</strong> ${r.date} | <strong>Shift:</strong> ${r.shift}</p><p><strong>Report #:</strong> ${r.referenceNo}</p></div></div>`;
    }else{
        h+=`<div class="border border-slate-200 rounded-2xl overflow-hidden mb-6 shadow-sm print-shadow-none">${r.coverPhoto?`<img src="${r.coverPhoto}" class="w-full ${isC?'h-16':'h-32'} object-cover"/>`:`<div class="w-full ${isC?'h-2':'h-4'} bg-slate-900"></div>`}<div class="p-6 bg-white border-t-4 border-indigo-500 flex justify-between items-center"><div class="flex items-center gap-4">${r.logo?`<img src="${r.logo}" class="h-12 max-w-[140px] object-contain"/>`:''}<div><h1 class="text-2xl font-black uppercase m-0 leading-none">Daily Progress Report</h1><p class="text-xs font-bold text-indigo-700 mt-1">${r.projectName}</p></div></div><div class="bg-slate-50 p-3 rounded-xl border text-xs text-right"><p><strong>Date:</strong> ${r.date} | <strong>Shift:</strong> ${r.shift}</p><p><strong>Report #:</strong> ${r.referenceNo}</p></div></div></div>`;
    }
    
    h+=`<div class="prose prose-sm sm:prose-base prose-slate prose-indigo max-w-none mt-6">${pMd}</div>`;
    
    if(r.photos&&r.photos.length>0){
        h+=`<div class="mt-10 pt-6 border-t-2"><h2 class="text-lg font-bold mb-4">Site Photos</h2><div class="grid grid-cols-2 gap-6">`;
        r.photos.forEach((ph,i)=>{if(!ph)return;h+=`<div class="border rounded-xl bg-slate-50 overflow-hidden shadow-sm">${ph.url?`<img src="${ph.url}" class="w-full h-64 object-contain bg-white"/>`:`<div class="w-full h-64 bg-slate-200 flex items-center justify-center">Image missing</div>`}<div class="p-3 border-t text-xs"><p class="font-bold">Photo ${i+1} - ${ph.category}</p><p class="mt-1">${ph.aiText||''}</p></div></div>`;});
        h+=`</div></div>`;
    }
    if(inc){ h+=`<div class="mt-12 pt-8 border-t-2"><h2 class="text-xl font-bold mb-4">Audit Log (${r.reviewStatus||'Open'})</h2><div class="grid grid-cols-2 gap-6 text-sm"><div class="bg-slate-50 p-4 border rounded-xl"><p class="font-bold">Remarks:</p><p>${r.reviewRemarks||'None'}</p></div><div class="bg-slate-50 p-4 border rounded-xl"><p class="font-bold">Action Taken:</p><p>${r.reviewActionTaken||'None'}</p></div></div></div>`; }
    h+=`<div class="mt-16 pt-8 border-t-2 flex justify-between"><div class="w-1/3 text-center"><div class="border-b border-slate-300 h-12 mb-2"></div><p class="font-bold text-sm">Prepared By</p></div><div class="w-1/3 text-center"><div class="border-b border-slate-300 h-12 mb-2"></div><p class="font-bold text-sm">Reviewed By</p><p class="text-xs text-slate-500">${r.supervisionConsultant||'Consultant'}</p></div></div>`;
    p.innerHTML=h;
}
window.renderReviewPanel = function() {
    const p=document.getElementById('review-collab-panel'); if(!p||!window.generatedReport)return; const s=window.generatedReport.reviewStatus||'Open';
    p.innerHTML=`<div class="bg-white border rounded-2xl p-5 shadow-lg space-y-4"><div class="flex justify-between items-center"><h3 class="font-bold text-xs uppercase"><i data-lucide="shield" class="inline w-4 h-4"></i> Audit Tracker</h3><span class="px-2 py-1 rounded text-[10px] font-bold ${s==='Closed'?'bg-emerald-50 text-emerald-700':'bg-rose-50 text-rose-700'}">${s}</span></div><select id="rev-s" class="w-full p-2 border rounded-xl text-xs"><option ${s==='Open'?'selected':''}>Open</option><option ${s==='Closed'?'selected':''}>Closed</option></select><textarea id="rev-r" placeholder="Remarks" class="w-full p-2 border rounded-xl text-xs h-20">${window.generatedReport.reviewRemarks||''}</textarea><textarea id="rev-a" placeholder="Action" class="w-full p-2 border rounded-xl text-xs h-20">${window.generatedReport.reviewActionTaken||''}</textarea><button onclick="window.saveReviewDetails(this)" class="w-full bg-slate-900 text-white p-2 rounded-xl text-xs font-bold">Save</button></div>`; if(typeof lucide!=='undefined')lucide.createIcons();
}
window.saveReviewDetails = async function(b) {
    if(!window.generatedReport)return; b.innerText='Saving...'; const s=document.getElementById('rev-s').value; const r=document.getElementById('rev-r').value; const a=document.getElementById('rev-a').value;
    window.generatedReport.reviewStatus=s; window.generatedReport.reviewRemarks=r; window.generatedReport.reviewActionTaken=a;
    const x=window.reportsList.findIndex(z=>z.dbId===window.generatedReport.dbId); if(x!==-1){window.reportsList[x].reviewStatus=s; window.reportsList[x].reviewRemarks=r; window.reportsList[x].reviewActionTaken=a;}
    if(db&&currentUser) await updateDoc(doc(db,'artifacts',appFirebaseId,'public','data','reports',window.generatedReport.docId||window.generatedReport.dbId),{reviewStatus:s,reviewRemarks:r,reviewActionTaken:a});
    b.innerText='Save'; window.renderViewReport('final'); window.updateReportsTables(); window.showCustomAlert("Saved","Audit updated.");
}
window.exportWordDoc = function() {
    if(!window.generatedReport)return; let c=document.getElementById('report-paper').cloneNode(true); c.querySelectorAll('.print-hidden,svg').forEach(e=>e.remove());
    const b=new Blob(['\ufeff',`<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'><head><meta charset='utf-8'><style>body{font-family:sans-serif}img{max-width:100%}</style></head><body>${c.innerHTML}</body></html>`],{type:'application/msword'});
    const a=document.createElement('a'); a.href=URL.createObjectURL(b); a.download=`Report_${window.generatedReport.referenceNo}.doc`; document.body.appendChild(a); a.click(); document.body.removeChild(a);
}
window.translateReport = async function(b) {
    if(!window.generatedReport)return; const k=window.userApiKey||apiKey; if(!k)return window.showCustomAlert("Error","API Key required.");
    b.innerText='Translating...'; try{ const p=`Translate to Arabic, keep Markdown:\n\n${window.generatedReport.markdown}`; const r=await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${k}`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({contents:[{parts:[{text:p}]}]})}); const d=await r.json(); window.generatedReport.markdown=d.candidates[0].content.parts[0].text; window.generatedReport.isArabic=true; window.renderViewReport('final'); }catch(e){}finally{b.innerText='Translated';}
}

window.openCompareModal = function() {
    const g=window.reportsList.filter(r=>!r.isManualDoc); if(g.length<2)return window.showCustomAlert("Error","Need 2 reports to compare.");
    const sA=document.getElementById('compare-report-a'); const sB=document.getElementById('compare-report-b'); let o=''; g.forEach(r=>{o+=`<option value="${r.dbId}">${r.date} - ${r.projectName}</option>`;});
    sA.innerHTML=o; sB.innerHTML=o; sA.value=g[1].dbId; sB.value=g[0].dbId;
    document.getElementById('compare-output-paper').classList.add('hidden'); document.getElementById('compare-placeholder').classList.remove('hidden'); document.getElementById('compare-modal').classList.remove('hidden');
}
window.closeCompareModal = function() { document.getElementById('compare-modal').classList.add('hidden'); }
window.runReportComparison = async function() {
    const k=window.userApiKey||apiKey; if(!k)return window.showCustomAlert("Error","API Key required."); const a=document.getElementById('compare-report-a').value; const b=document.getElementById('compare-report-b').value; if(a===b)return window.showCustomAlert("Error","Select different reports.");
    const rA=window.reportsList.find(x=>x.dbId===a); const rB=window.reportsList.find(x=>x.dbId===b); if(!rA||!rB)return;
    const btn=document.getElementById('btn-run-compare'); btn.innerText='Analyzing...'; document.getElementById('compare-placeholder').classList.remove('hidden'); document.getElementById('compare-output-paper').classList.add('hidden');
    try{
        const p=`Compare these reports:\n\nOLD (${rA.date}):\n${rA.markdown}\n\nNEW (${rB.date}):\n${rB.markdown}\n\nReturn Markdown:\n## Progress Made\n## Issues & Delays\n## Resource Changes`;
        const r=await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${k}`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({contents:[{parts:[{text:p}]}]})});
        const d=await r.json(); const md=d.candidates[0].content.parts[0].text;
        document.getElementById('compare-output-paper').innerHTML=`<div class="prose prose-slate prose-indigo max-w-none">${typeof marked!=='undefined'?marked.parse(md):`<pre>${md}</pre>`}</div>`;
        document.getElementById('compare-placeholder').classList.add('hidden'); document.getElementById('compare-output-paper').classList.remove('hidden');
    }catch(e){}finally{btn.innerHTML=`<i data-lucide="sparkles" class="inline w-4 h-4"></i> Analyze`; if(typeof lucide!=='undefined')lucide.createIcons();}
}

document.addEventListener("DOMContentLoaded", () => {
    if(sessionStorage.getItem('appUnlocked')==='true') document.getElementById('app-lock-overlay').classList.add('hidden');
    try{const s=localStorage.getItem('lookAheadData'); if(s)window.lookAheadData=JSON.parse(s); const k=localStorage.getItem('keepLookAheadToggle'); const t=document.getElementById('lock-lookahead-toggle'); if(t&&k==='true')t.checked=true;}catch(e){}
    window.renderLookAheadTable(); window.loadQuickCapture(); window.loadMainPhotos(); window.renderSitePlan();
});
if(typeof lucide!=='undefined')lucide.createIcons();
</script>
</body>
</html>
