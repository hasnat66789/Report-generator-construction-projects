@media print{body{background:#fff!important}.print-hidden{display:none!important}.print-break-inside-avoid{break-inside:avoid!important}.page-break{break-before:page!important;page-break-before:always!important;border:0!important;margin:0!important;padding:0!important;height:0!important;display:block!important}.prose{color:#000!important}}
.page-break{width:100%;height:2px;background:#e2e8f0;border-top:1px dashed #94a3b8;margin:2rem 0;display:block;position:relative;clear:both}
.view-section{display:none}.view-section.active{display:block}
.premium-input{transition:all .2s}.premium-input:focus{border-color:#6366f1;box-shadow:0 0 0 4px rgba(99,102,241,.1)}
</style>
</head>
<body class="flex flex-col md:flex-row text-slate-800 bg-slate-50/50 min-h-screen overflow-x-hidden">

<div id="app-lock-overlay" class="fixed inset-0 bg-slate-950 z-[99999] flex flex-col items-center justify-center transition-opacity duration-500">
<div class="bg-slate-900 p-8 rounded-3xl shadow-2xl border border-slate-800 w-full max-w-sm text-center relative mx-4"><div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-indigo-500 to-purple-500"></div><div class="w-16 h-16 bg-indigo-500/10 text-indigo-500 rounded-2xl flex items-center justify-center mx-auto mb-6"><i data-lucide="lock" class="w-8 h-8"></i></div><h2 class="text-2xl font-bold text-white mb-2">App Secured</h2><p class="text-slate-400 text-sm mb-6">Enter access password.</p><input type="password" id="app-lock-input" class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3 text-white focus:outline-none mb-4 text-center tracking-widest shadow-inner" placeholder="••••••••" onkeydown="if(event.key==='Enter') window.unlockApp()" /><button onclick="window.unlockApp()" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 rounded-xl transition shadow-lg flex items-center justify-center gap-2"><i data-lucide="key" class="w-4 h-4"></i> Unlock App</button><p id="app-lock-error" class="text-rose-500 text-xs mt-4 hidden font-semibold animate-pulse">Incorrect password.</p></div>
</div>

<div id="mobile-overlay" onclick="window.toggleMobileMenu(true)" class="fixed inset-0 bg-slate-900/80 z-40 hidden backdrop-blur-sm transition-opacity opacity-0 md:hidden"></div>
<div class="md:hidden bg-slate-950 text-white p-4 flex items-center justify-between sticky top-0 z-30 shadow-md w-full"><div class="flex items-center gap-2.5"><div class="p-1.5 bg-gradient-to-tr from-indigo-500 to-blue-400 rounded-lg"><i data-lucide="hard-hat" class="w-5 h-5"></i></div><span class="text-base font-bold">Construction Reports</span></div><button onclick="window.toggleMobileMenu()" class="p-2 bg-slate-800 rounded-lg"><i data-lucide="menu" class="w-6 h-6"></i></button></div>

<aside id="sidebar" class="w-64 bg-slate-950 text-white flex flex-col h-screen fixed left-0 top-0 print-hidden z-50 border-r border-slate-900 shadow-xl transform -translate-x-full md:translate-x-0 transition-transform duration-300">
<div class="p-6 flex flex-col gap-1.5 border-b border-slate-800 bg-slate-950 relative"><button onclick="window.toggleMobileMenu()" class="md:hidden absolute top-4 right-4 text-slate-400"><i data-lucide="x" class="w-5 h-5"></i></button><div class="flex items-center gap-3"><div class="p-2 bg-gradient-to-tr from-indigo-500 to-blue-400 rounded-xl"><i data-lucide="hard-hat" class="w-5 h-5"></i></div><span class="text-base font-bold leading-tight">Construction Reports</span></div><span class="text-[10px] uppercase text-slate-500 font-semibold ml-10">by TYA & Associates</span></div>
<nav class="flex-1 p-4 space-y-1.5 overflow-y-auto">
<button onclick="window.switchView('dashboard')" class="nav-btn w-full flex items-center gap-3.5 px-4 py-3 rounded-xl bg-indigo-600 text-white font-medium text-sm shadow-lg" data-target="dashboard"><i data-lucide="home" class="w-4.5 h-4.5"></i><span>Dashboard</span></button>
<button onclick="window.switchView('create_report')" class="nav-btn w-full flex items-center gap-3.5 px-4 py-3 rounded-xl hover:bg-slate-900 text-slate-400 font-medium text-sm" data-target="create_report"><i data-lucide="plus-circle" class="w-4.5 h-4.5"></i><span>New Report</span></button>
<button onclick="window.switchView('quick_capture')" class="nav-btn w-full flex items-center gap-3.5 px-4 py-3 rounded-xl hover:bg-slate-900 text-slate-400 font-medium text-sm" data-target="quick_capture"><i data-lucide="camera" class="w-4.5 h-4.5"></i><span>Field Capture</span></button>
<button onclick="window.switchView('upload_documents')" class="nav-btn w-full flex items-center gap-3.5 px-4 py-3 rounded-xl hover:bg-slate-900 text-slate-400 font-medium text-sm" data-target="upload_documents"><i data-lucide="upload-cloud" class="w-4.5 h-4.5"></i><span>Documents</span></button>
<button onclick="window.switchView('safety_reports')" class="nav-btn w-full flex items-center gap-3.5 px-4 py-3 rounded-xl hover:bg-slate-900 text-slate-400 font-medium text-sm" data-target="safety_reports"><i data-lucide="shield-check" class="w-4.5 h-4.5"></i><span>Safety Reports</span></button>
<button onclick="window.switchView('archives')" class="nav-btn w-full flex items-center gap-3.5 px-4 py-3 rounded-xl hover:bg-slate-900 text-slate-400 font-medium text-sm" data-target="archives"><i data-lucide="file-text" class="w-4.5 h-4.5"></i><span>Archives</span></button>
<button onclick="window.switchView('team_directory')" class="nav-btn w-full flex items-center gap-3.5 px-4 py-3 rounded-xl hover:bg-slate-900 text-slate-400 font-medium text-sm" data-target="team_directory"><i data-lucide="users" class="w-4.5 h-4.5"></i><span>Team</span></button>
<button onclick="window.switchView('submittals')" class="nav-btn w-full flex items-center gap-3.5 px-4 py-3 rounded-xl hover:bg-slate-900 text-slate-400 font-medium text-sm" data-target="submittals"><i data-lucide="file-spreadsheet" class="w-4.5 h-4.5"></i><span>Submittals</span></button>
<button onclick="window.switchView('settings')" class="nav-btn w-full flex items-center gap-3.5 px-4 py-3 rounded-xl hover:bg-slate-900 text-slate-400 font-medium text-sm" data-target="settings"><i data-lucide="settings" class="w-4.5 h-4.5"></i><span>Settings</span></button>
</nav>
<div class="p-4 border-t border-slate-900 bg-slate-950/80"><div class="flex items-center gap-3 px-3 py-1"><div id="sidebar-profile-avatar" class="w-9 h-9 rounded-xl bg-gradient-to-tr from-indigo-500 to-blue-500 flex items-center justify-center font-bold text-xs shadow-md">HS</div><div class="flex-1 min-w-0"><p id="sidebar-profile-name" class="text-sm font-semibold truncate text-slate-100">Hasnat Safdar</p><p id="sidebar-profile-role" class="text-[10px] text-slate-400 uppercase tracking-wider">App Developer</p></div></div><div class="px-3 pb-1 border-t border-slate-900/50 mt-3 pt-2.5 flex items-center justify-between"><p class="text-[11px] text-slate-400 flex items-center gap-2"><span id="db-status-dot" class="w-2 h-2 rounded-full bg-yellow-500"></span><span id="db-status-text">Connecting...</span></p></div></div>
</aside>

<main class="flex-1 md:ml-64 p-4 sm:p-6 md:p-8 relative print-m-0 print-p-0 print-w-full overflow-x-hidden">
<div class="static md:absolute top-8 right-8 flex flex-wrap items-center justify-end gap-3 bg-white p-2.5 rounded-2xl border border-slate-200 shadow-sm z-30 print-hidden mb-6 md:mb-0"><div id="api-indicator" class="w-2.5 h-2.5 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.5)] transition-colors"></div><input type="password" id="api-key-input" placeholder="Custom API Key (Optional)" class="text-xs p-1 outline-none border-b border-slate-100 focus:border-indigo-500 w-32 sm:w-44 bg-transparent"><button onclick="window.connectApi()" id="connect-btn" class="text-[11px] bg-slate-900 hover:bg-slate-800 text-white px-3.5 py-1.5 rounded-xl font-semibold transition-all">Connect</button></div>

<section id="dashboard" class="view-section active pb-24">
<div class="relative w-full h-72 rounded-3xl overflow-hidden mb-8 shadow-2xl group flex items-end bg-slate-950"><div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/60 to-transparent z-10"></div><img id="dashboard-cover-img" src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=2070" class="absolute inset-0 w-full h-full object-cover transition-all" /><div class="absolute bottom-0 left-0 p-8 z-20 w-full flex justify-between items-end"><div><span class="px-3.5 py-1.5 bg-indigo-500/20 text-indigo-300 border border-indigo-500/30 rounded-full text-[10px] font-black uppercase tracking-widest backdrop-blur-md mb-4 inline-block shadow-lg">Active Project</span><h1 class="text-4xl sm:text-5xl font-extrabold text-white tracking-tight drop-shadow-lg" id="hero-project-name">Active Project</h1><p class="text-slate-300 mt-2.5 font-medium flex items-center gap-2 text-sm"><i data-lucide="map-pin" class="w-4.5 h-4.5 text-indigo-400"></i><span id="hero-location">Yanbu, KSA</span></p></div><div class="hidden md:flex flex-col items-end gap-3"><img id="dashboard-logo-img" src="" class="h-10 max-w-[150px] object-contain hidden rounded-lg border border-white/20 p-1 bg-white/10 backdrop-blur-md" /><p class="text-slate-400 text-xs mt-1">Welcome back, <span class="profile-name-span font-bold text-white">Hasnat</span>.</p></div></div></div>
<div id="announcement-banner" class="hidden mb-8 bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200/60 rounded-2xl p-4 flex items-center gap-4 relative overflow-hidden"><div class="absolute left-0 top-0 w-1.5 h-full bg-blue-500"></div><div class="p-2.5 bg-blue-100 text-blue-600 rounded-xl animate-pulse"><i data-lucide="megaphone" class="w-5 h-5"></i></div><div class="ticker-container flex-1"><p id="announcement-text" class="ticker-text text-sm font-bold text-blue-900 uppercase"></p></div></div>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
<div class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm flex items-center gap-4"><div class="p-3.5 rounded-xl bg-blue-50 text-blue-600"><i data-lucide="file-text"></i></div><div><p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Total Reports</p><p class="text-2xl font-bold mt-1" id="stat-total-reports">0</p></div></div>
<div class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm flex items-center gap-4"><div class="p-3.5 rounded-xl bg-emerald-50 text-emerald-600"><i data-lucide="users"></i></div><div><p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Avg Manpower</p><input type="text" id="stat-avg-workforce" value="350" onchange="window.updateStat('avgWorkforce',this.value)" class="text-2xl font-bold bg-transparent w-full outline-none" /></div></div>
<div class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm flex items-center gap-4"><div class="p-3.5 rounded-xl bg-indigo-50 text-indigo-600"><i data-lucide="calendar"></i></div><div><p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Total Days</p><p class="text-2xl font-bold mt-1" id="stat-total-days">--</p></div></div>
<div class="bg-white rounded-2xl p-5 border border-slate-100 shadow-sm flex items-center gap-4"><div class="p-3.5 rounded-xl bg-rose-50 text-rose-600"><i data-lucide="hourglass"></i></div><div><p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Remaining Days</p><p class="text-2xl font-bold mt-1" id="stat-remaining-days">--</p></div></div>
</div>
<div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 mb-8 relative"><div class="flex justify-between items-center mb-5"><h2 class="text-base font-bold flex items-center gap-2"><i data-lucide="timer" class="w-5 h-5 text-indigo-500"></i> Live Project Timeline</h2><div id="timeline-badge" class="px-3 py-1.5 text-[10px] uppercase font-bold rounded-full bg-slate-100 text-slate-600"><span id="badge-text">Calculating...</span></div></div><div class="flex flex-col lg:flex-row gap-8 items-center"><div class="flex-1 w-full"><div class="flex justify-between text-xs font-bold text-slate-500 mb-2"><span id="timeline-start-text">Start: --</span><span id="timeline-end-text">Target: --</span></div><div class="h-4 w-full bg-slate-100 rounded-full overflow-hidden flex"><div id="timeline-progress-done" class="h-full bg-indigo-500 transition-all duration-1000" style="width:0%"></div><div id="timeline-progress-rem" class="h-full bg-slate-200 transition-all duration-1000" style="width:100%"></div></div><div class="flex justify-between text-[10px] uppercase font-extrabold mt-2"><span id="timeline-pct-done" class="text-indigo-600">0% Done</span><span id="timeline-pct-rem" class="text-slate-400">100% Rem</span></div></div><div class="w-full lg:w-auto bg-slate-950 p-5 rounded-2xl shadow-2xl text-center"><h3 class="text-white text-sm font-black tracking-widest uppercase mb-4" id="timeline-status-label">Target Completion</h3><div id="timeline-countdown" class="flex gap-2 justify-center text-white"><div class="flex flex-col"><span class="text-[9px] text-slate-400 uppercase">Days</span><div id="cd-block-days" class="bg-slate-800 rounded-xl px-3 py-2 font-black text-2xl">--</div></div><span class="text-2xl pt-4">:</span><div class="flex flex-col"><span class="text-[9px] text-slate-400 uppercase">Hrs</span><div id="cd-block-hours" class="bg-slate-800 rounded-xl px-3 py-2 font-black text-2xl">--</div></div><span class="text-2xl pt-4">:</span><div class="flex flex-col"><span class="text-[9px] text-slate-400 uppercase">Min</span><div id="cd-block-mins" class="bg-slate-800 rounded-xl px-3 py-2 font-black text-2xl">--</div></div></div></div></div></div>
<div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 mb-8"><div class="flex justify-between items-center mb-5 border-b pb-3"><h2 class="text-base font-bold flex items-center gap-2"><i data-lucide="map" class="text-indigo-500 w-5 h-5"></i> Site Plan Progress</h2><div class="flex gap-2"><button id="btn-toggle-pin" onclick="window.togglePinMode()" class="hidden bg-indigo-50 text-indigo-700 px-3 py-1.5 rounded-xl text-xs font-bold"><i data-lucide="map-pin" class="w-3.5 h-3.5 inline"></i> Add Pin</button><label class="cursor-pointer bg-slate-50 border px-3 py-1.5 rounded-xl text-xs font-bold"><i data-lucide="upload" class="w-3.5 h-3.5 inline"></i> <span id="site-plan-btn-text">Upload Plan</span><input type="file" accept="image/*" class="hidden" onchange="window.handleSitePlanUpload(event)"/></label><button id="btn-clear-plan" onclick="window.clearSitePlan()" class="hidden bg-rose-50 text-rose-700 border-rose-200 border px-3 py-1.5 rounded-xl text-xs font-bold"><i data-lucide="trash-2" class="w-3.5 h-3.5 inline"></i> Clear</button></div></div><div id="site-plan-container" class="relative w-full h-[400px] bg-slate-50 rounded-xl border-2 border-dashed border-slate-200 flex items-center justify-center overflow-hidden"><div id="site-plan-empty" class="text-center text-slate-400 pointer-events-none"><i data-lucide="map" class="w-12 h-12 mx-auto mb-2 opacity-30"></i><p class="font-semibold text-sm">No plan uploaded.</p></div></div></div>
<div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6"><div class="flex justify-between items-center mb-6"><h2 class="text-base font-bold text-slate-900">Recent Logs & Audits</h2><button onclick="window.switchView('archives')" class="text-indigo-600 text-xs font-semibold">View All</button></div><div class="overflow-x-auto"><table class="w-full text-left"><thead class="border-b text-xs font-bold text-slate-400 uppercase"><th class="pb-3">Date</th><th class="pb-3">Project</th><th class="pb-3">Author</th><th class="pb-3">Status</th><th class="pb-3 text-right">Action</th></thead><tbody id="dashboard-recent-reports" class="divide-y text-sm"><tr><td colspan="5" class="py-8 text-center text-slate-400">No reports generated yet.</td></tr></tbody></table></div></div>
</section>

<section id="create_report" class="view-section pb-24">
<header class="mb-8"><h1 class="text-2xl font-extrabold tracking-tight">Generate Daily Report</h1><p class="text-slate-500 text-sm">Input data, look-ahead activities, and photos.</p></header>
<div class="max-w-5xl space-y-6">
<div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6"><div class="flex justify-between items-center mb-4"><h2 class="font-bold flex items-center gap-2"><i data-lucide="image" class="text-indigo-500 w-5 h-5"></i> Cover Photo</h2></div><div class="flex items-center gap-4"><div class="relative"><img id="form-cover-preview" class="w-48 h-24 object-cover rounded-xl hidden" /><button id="form-cover-remove" onclick="window.removeFormCover()" class="absolute -top-2 -right-2 bg-red-500 text-white p-1.5 rounded-full hidden"><i data-lucide="x" class="w-3 h-3"></i></button></div><label class="cursor-pointer bg-indigo-50 text-indigo-700 px-5 py-3 rounded-xl text-xs font-bold"><i data-lucide="upload" class="inline w-4 h-4"></i> Upload Cover<input type="file" accept="image/*" class="hidden" onchange="window.handleFormCoverUpload(event)"/></label></div></div>
